{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenvra.ai/schemas/result-attestation.v0.schema.json",
  "title": "Tenvra Result Attestation v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "jobId",
    "nodeId",
    "manifestHash",
    "imageDigest",
    "startedAt",
    "finishedAt",
    "exitCode",
    "artifactHashes",
    "signature"
  ],
  "properties": {
    "protocolVersion": { "type": "string", "pattern": "^0\\." },
    "jobId": { "type": "string", "minLength": 1 },
    "nodeId": { "type": "string", "minLength": 1 },
    "manifestHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "imageDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "exitCode": { "type": "integer" },
    "artifactHashes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
    },
    "signature": { "type": "string", "minLength": 1 }
  }
}
