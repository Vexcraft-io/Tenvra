{
  "name": "tenvra",
  "version": "0.0.0",
  "private": true,
  "description": "Open coding intelligence, built and shared by contributors.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "contracts:validate": "ajv compile --spec=draft2020 -c ajv-formats -s \"packages/contracts/schemas/*.schema.json\"",
    "dev": "turbo run dev",
    "format": "prettier --write \"apps/**/*\" \"packages/**/*\" \"infrastructure/**/*\" \"docs/**/*\" \".github/**/*\" \".vscode/**/*\" \"*.{md,json,yml,yaml}\" --ignore-unknown",
    "format:check": "prettier --check \"apps/**/*\" \"packages/**/*\" \"infrastructure/**/*\" \"docs/**/*\" \".github/**/*\" \".vscode/**/*\" \"*.{md,json,yml,yaml}\" --ignore-unknown",
    "lint": "turbo run lint",
    "supabase:db:lint": "supabase --workdir infrastructure db lint --local --schema public --fail-on error",
    "supabase:db:reset": "supabase --workdir infrastructure db reset --local",
    "supabase:db:test": "supabase --workdir infrastructure test db infrastructure/supabase/tests --local",
    "supabase:start": "supabase --workdir infrastructure start",
    "supabase:status": "supabase --workdir infrastructure status",
    "supabase:stop": "supabase --workdir infrastructure stop",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.6.2",
    "supabase": "^2.107.0",
    "turbo": "^2.5.6",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  }
}
